# Prefect Horizon / local FastMCP server
LASTFM_API_KEY=
MUSICBRAINZ_USER_AGENT=MOODWAVE/0.1 (your-email@example.com)
MUSICBRAINZ_CONTACT=your-email@example.com

# Neon pooled PostgreSQL connection string. Keep sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Local-only fallback when DATABASE_URL is absent.
DATABASE_PATH=./data/moodwave.db
